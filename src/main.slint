import {
    Button,
    CheckBox,
    Slider,
    LineEdit,
    ScrollView,
    ListView,
    ComboBox,
} from "std-widgets.slint";

// ── Embedded fonts ─────────────────────────────────────────
import "../ui/fonts/StackSansHeadline-Extralight.ttf";
import "../ui/fonts/StackSansHeadline-Light.ttf";
import "../ui/fonts/StackSansHeadline-Regular.ttf";
import "../ui/fonts/StackSansHeadline-Medium.ttf";
import "../ui/fonts/StackSansHeadline-SemiBold.ttf";
import "../ui/fonts/StackSansHeadline-Bold.ttf";

export struct FileItem {
    relative-path: string,
    status: string,
    selected: bool,
    error-message: string,
    current-page: int,
    total-pages: int,
}

component FileRow {
    in-out property <int> index;
    in-out property <FileItem> file-item;
    callback toggled;

    HorizontalLayout {
        spacing: 6px;
        padding-left: 8px;
        padding-right: 6px;
        padding-top: 3px;
        padding-bottom: 3px;
        height: 30px;

        CheckBox {
            checked: file-item.selected;
            toggled => {
                root.toggled();
            }
        }

        Rectangle {
            width: 16px;
            height: 16px;
            border-radius: 8px;
            background: file-item.status == "done" ? #4caf50 : file-item.status == "error" ? #f44336 : file-item.status == "processing" ? #2196f3 : file-item.status == "skipped" ? #ff9800 : #40444b;
            Text {
                text: file-item.status == "done" ? "✓" : file-item.status == "error" ? "✗" : file-item.status == "processing" ? "⟳" : file-item.status == "skipped" ? "⏭" : "";
                color: white;
                font-size: 10px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: file-item.relative-path;
            font-size: 12px;
            color: file-item.status == "error" ? #ef5350 : file-item.status == "done" ? #66bb6a : file-item.status == "skipped" ? #ffa726 : #dcddde;
            horizontal-stretch: 1;
            overflow: elide;
        }

        Text {
            text: file-item.status == "processing" && file-item.total-pages > 0 ? "page " + file-item.current-page + "/" + file-item.total-pages : "";
            font-size: 11px;
            color: #8e9297;
            visible: file-item.status == "processing" && file-item.total-pages > 0;
        }

        Text {
            text: file-item.error-message;
            font-size: 11px;
            color: #ef5350;
            visible: file-item.error-message != "";
        }
    }
}

// ── Completion Dialog ──────────────────────────────────────
component CompletionDialog {
    in-out property <bool> show;
    in-out property <int> n-total;
    in-out property <int> n-ok;
    in-out property <int> n-err;
    in-out property <int> n-skip;
    in-out property <length> win-width;
    in-out property <length> win-height;
    callback dismiss;
    width: 100%;
    height: 100%;

    if show: Rectangle {
        background: #000000b0;
        x: 0;
        y: 0;
        width: root.win-width;
        height: root.win-height;

        Rectangle {
            width: 340px;
            height: 200px;
            background: #2f3136;
            border-radius: 12px;
            border-width: 1px;
            border-color: #40444b;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;

            VerticalLayout {
                padding: 20px;
                spacing: 10px;

                Text {
                    text: "✓ Conversion Complete";
                    color: #7fb88f;
                    font-size: 18px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                Text {
                    text: n-ok + " of " + n-total + " PDFs splitted and converted";
                    color: #dcddde;
                    font-size: 12px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 14px;
                    alignment: center;
                    Text {
                        text: "✓ " + n-ok;
                        color: #7fb88f;
                        font-size: 13px;
                        visible: n-ok > 0;
                    }

                    Text {
                        text: "✗ " + n-err;
                        color: #ef5350;
                        font-size: 13px;
                        visible: n-err > 0;
                    }

                    Text {
                        text: "⏭ " + n-skip;
                        color: #ffa726;
                        font-size: 13px;
                        visible: n-skip > 0;
                    }
                }

                Button {
                    text: "OK";
                    min-width: 100px;
                    clicked => {
                        root.dismiss();
                    }
                }
            }
        }
    }
}

// ── Main Window ────────────────────────────────────────────
export component MainWindow inherits Window {
    title: "pdf2webp — PDF to WebP Converter";
    default-font-family: "Stack Sans Headline";
    background: #202225;
    preferred-width: 900px;
    preferred-height: 640px;
    icon: @image-url("../ui/assets/appicon.svg");

    in-out property <string> source-path;
    in-out property <string> output-path;
    in-out property <int> output-format-index: 0;
    in-out property <float> dpi-value: 150;
    in-out property <float> quality-value: 75;
    in-out property <bool> adaptive-encoding: true;
    in-out property <float> quality-target: 85;
    in-out property <float> svg-precision: 4;
    in-out property <bool> svg-embed-fonts-as-paths: false;
    in-out property <bool> svg-strip-background: true;
    in-out property <bool> overwrite: false;
    in-out property <bool> processing: false;
    in-out property <bool> scanning: false;
    in-out property <int> total-files: 0;
    in-out property <int> selected-count: 0;
    in-out property <int> processed-count: 0;
    in-out property <int> error-count: 0;
    in-out property <int> skipped-count: 0;
    in-out property <[FileItem]> file-model;
    in-out property <string> status-text: "Select source folder and scan for PDFs";
    in-out property <bool> show-dialog: false;
    in-out property <bool> update-available: false;
    in-out property <string> update-version: "";
    in-out property <bool> updating: false;
    in-out property <bool> source-valid: source-path != "";

    in-out property <float> pct: total-files > 0 ? (processed-count + error-count + skipped-count) * 100.0 / total-files : 0.0;
    in-out property <bool> can-process: total-files > 0 && !processing && !scanning;

    callback select-source-folder();
    callback select-output-folder();
    callback start-conversion();
    callback stop-conversion();
    callback scan-source();
    callback toggle-all-files(bool);
    callback toggle-file(int);
    callback apply-update();

    // ═══ ROOT: Sidebar + Main pane ═══════════════════════════
    HorizontalLayout {
        spacing: 0;

        // ═══ SIDEBAR (fixed 240px) ═══════════════════════════
        Rectangle {
            width: 240px;
            background: #2f3136;

            VerticalLayout {
                padding: 14px;
                spacing: 12px;

                // Logo
                Image {
                    source: @image-url("../ui/assets/logo.svg");
                    width: 120px;
                    height: 24px;
                }

                Text {
                    text: "PDF to WebP Converter";
                    font-size: 10px;
                    color: #8e9297;
                }

                // ── Source ────────────────────────────────────
                Text {
                    text: "Source Folder";
                    font-size: 10px;
                    color: #b9bbbe;
                    font-weight: 600;
                }

                HorizontalLayout {
                    spacing: 4px;
                    LineEdit {
                        text <=> root.source-path;
                        placeholder-text: "Select...";
                        horizontal-stretch: 1;
                        read-only: true;
                    }

                    Rectangle {
                        width: 32px;
                        height: 32px;
                        border-radius: 4px;
                        background: source-browse-area.has-hover ? #40444b : transparent;
                        border-width: 1px;
                        border-color: #40444b;

                        Image {
                            source: @image-url("../ui/assets/folder-open.svg");
                            width: 18px;
                            height: 18px;
                        }

                        source-browse-area := TouchArea {
                            clicked => {
                                root.select-source-folder();
                            }
                        }
                    }
                }

                // ── Output ────────────────────────────────────
                Text {
                    text: "Output Folder";
                    font-size: 10px;
                    color: #b9bbbe;
                    font-weight: 600;
                }

                HorizontalLayout {
                    spacing: 4px;
                    LineEdit {
                        text <=> root.output-path;
                        placeholder-text: "Select...";
                        horizontal-stretch: 1;
                        read-only: true;
                    }

                    Rectangle {
                        width: 32px;
                        height: 32px;
                        border-radius: 4px;
                        background: output-browse-area.has-hover ? #40444b : transparent;
                        border-width: 1px;
                        border-color: #40444b;

                        Image {
                            source: @image-url("../ui/assets/folder-open.svg");
                            width: 18px;
                            height: 18px;
                        }

                        output-browse-area := TouchArea {
                            clicked => {
                                root.select-output-folder();
                            }
                        }
                    }
                }

                // ── DPI ───────────────────────────────────────
                Text {
                    text: "DPI (" + root.dpi-value + ")";
                    font-size: 10px;
                    color: #b9bbbe;
                    font-weight: 600;
                }

                Slider {
                    minimum: 90;
                    maximum: 200;
                    value: root.dpi-value;
                    changed(v) => {
                        root.dpi-value = v;
                    }
                    enabled: !root.processing;
                }

                // ── Adaptive quality toggle ───────────────────
                HorizontalLayout {
                    spacing: 4px;
                    alignment: start;

                    CheckBox {
                        text: "";
                        checked <=> root.adaptive-encoding;
                    }

                    Text {
                        text: "Adaptive Quality";
                        color: #dcddde;
                        font-size: 12px;
                        vertical-alignment: center;
                    }

                    Image {
                        source: @image-url("../ui/assets/sparkles.svg");
                        width: 14px;
                        height: 14px;
                    }
                }

                if root.adaptive-encoding: VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Quality Target (" + root.quality-target + " / 100)";
                        font-size: 10px;
                        color: #b9bbbe;
                        font-weight: 600;
                    }

                    Slider {
                        minimum: 70;
                        maximum: 95;
                        value: root.quality-target;
                        changed(v) => {
                            root.quality-target = v;
                        }
                    }

                    Text {
                        text: "Higher = crisper but larger. 85 is visually lossless for most documents.";
                        font-size: 9px;
                        color: #8e9297;
                        wrap: word-wrap;
                    }
                }

                if !root.adaptive-encoding: VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Quality (" + root.quality-value + "%)";
                        font-size: 10px;
                        color: #b9bbbe;
                        font-weight: 600;
                    }

                    Slider {
                        minimum: 1;
                        maximum: 100;
                        value: root.quality-value;
                        changed(v) => {
                            root.quality-value = v;
                        }
                        enabled: !root.processing;
                    }
                }

                // ── Overwrite ─────────────────────────────────
                CheckBox {
                    text: "Overwrite existing files";
                    checked <=> root.overwrite;
                    enabled: !root.processing;
                }

                // ── Separator ─────────────────────────────────
                Rectangle {
                    height: 1px;
                    background: #40444b;
                }

                // ── Scan / Select buttons ─────────────────────
                Text {
                    text: "File Selection";
                    font-size: 10px;
                    color: #b9bbbe;
                    font-weight: 600;
                }

                Rectangle {
                    height: 32px;
                    border-radius: 4px;
                    background: scan-area.has-hover && root.source-valid ? #40444b : root.source-valid ? #2f3136 : #252729;
                    border-width: 1px;
                    border-color: #40444b;
                    opacity: root.source-valid ? 1.0 : 0.4;

                    VerticalLayout {
                        alignment: center;
                        HorizontalLayout {
                            spacing: 6px;
                            padding-left: 10px;
                            padding-right: 10px;
                            alignment: center;
                            Image {
                                source: @image-url("../ui/assets/search.svg");
                                width: 14px;
                                height: 14px;
                            }

                            Text {
                                text: "Scan for PDFs";
                                color: #dcddde;
                                font-size: 12px;
                            }
                        }
                    }

                    scan-area := TouchArea {
                        enabled: root.source-valid;
                        clicked => {
                            root.scan-source();
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 4px;
                    Rectangle {
                        height: 32px;
                        horizontal-stretch: 1;
                        border-radius: 4px;
                        background: sel-all-area.has-hover && (root.total-files > 0 && !root.processing) ? #40444b : #2f3136;
                        border-width: 1px;
                        border-color: #40444b;
                        opacity: (root.total-files > 0 && !root.processing) ? 1.0 : 0.4;

                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                spacing: 6px;
                                padding-left: 8px;
                                padding-right: 8px;
                                alignment: center;
                                Image {
                                    source: @image-url("../ui/assets/check.svg");
                                    width: 18px;
                                    height: 18px;
                                }

                                Text {
                                    text: "Select All";
                                    color: #dcddde;
                                    font-size: 12px;
                                }
                            }
                        }

                        sel-all-area := TouchArea {
                            enabled: root.total-files > 0 && !root.processing;
                            clicked => {
                                root.toggle-all-files(true);
                            }
                        }
                    }

                    Rectangle {
                        height: 32px;
                        horizontal-stretch: 1;
                        border-radius: 4px;
                        background: desel-area.has-hover && (root.total-files > 0 && !root.processing) ? #40444b : #2f3136;
                        border-width: 1px;
                        border-color: #40444b;
                        opacity: (root.total-files > 0 && !root.processing) ? 1.0 : 0.4;

                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                spacing: 6px;
                                padding-left: 8px;
                                padding-right: 8px;
                                alignment: center;
                                Image {
                                    source: @image-url("../ui/assets/x.svg");
                                    width: 18px;
                                    height: 18px;
                                }

                                Text {
                                    text: "Deselect";
                                    color: #dcddde;
                                    font-size: 12px;
                                }
                            }
                        }

                        desel-area := TouchArea {
                            enabled: root.total-files > 0 && !root.processing;
                            clicked => {
                                root.toggle-all-files(false);
                            }
                        }
                    }
                }

                // ── Spacer (pushes Start/Stop to bottom) ─────
                Rectangle {
                    vertical-stretch: 1;
                }

                // ── Start/Stop buttons ────────────────────────
                HorizontalLayout {
                    spacing: 4px;
                    Rectangle {
                        height: 32px;
                        horizontal-stretch: 1;
                        border-radius: 4px;
                        background: start-area.has-hover && root.can-process ? #3a4f3c : root.can-process ? #425744 : #2f3136;
                        border-width: 1px;
                        border-color: root.can-process ? #425744 : #40444b;
                        opacity: root.can-process ? 1.0 : 0.4;

                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                spacing: 6px;
                                padding-left: 10px;
                                padding-right: 10px;
                                alignment: center;
                                Image {
                                    source: @image-url("../ui/assets/play.svg");
                                    width: 18px;
                                    height: 18px;
                                }

                                Text {
                                    text: "Start";
                                    color: #ffffff;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                            }
                        }

                        start-area := TouchArea {
                            enabled: root.can-process;
                            clicked => {
                                root.start-conversion();
                            }
                        }
                    }

                    Rectangle {
                        height: 32px;
                        horizontal-stretch: 1;
                        border-radius: 4px;
                        background: stop-area.has-hover && root.processing ? #5a2a2a : root.processing ? #3a1a1a : #2f3136;
                        border-width: 1px;
                        border-color: root.processing ? #7a3535 : #40444b;
                        opacity: root.processing ? 1.0 : 0.4;

                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                spacing: 6px;
                                padding-left: 10px;
                                padding-right: 10px;
                                alignment: center;
                                Image {
                                    source: @image-url("../ui/assets/square.svg");
                                    width: 18px;
                                    height: 18px;
                                }

                                Text {
                                    text: "Stop";
                                    color: #ef5350;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                            }
                        }

                        stop-area := TouchArea {
                            enabled: root.processing;
                            horizontal-stretch: 1;
                            clicked => {
                                root.stop-conversion();
                            }
                        }
                    }
                }
            }
        }

        // ═══ RIGHT PANE ──────────────────────────────────────
        VerticalLayout {
            padding: 10px;
            spacing: 6px;
            horizontal-stretch: 1;

            // ── Update banner ────────────────────────────────
            if root.update-available: Rectangle {
                background: #425744;
                border-radius: 6px;
                height: 36px;

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    padding-top: 6px;
                    padding-bottom: 6px;
                    spacing: 8px;

                    Text {
                        text: root.updating ? "Updating to v" + root.update-version + "…" : "Update available: v" + root.update-version;
                        color: #ffffff;
                        font-size: 12px;
                        font-weight: 600;
                        horizontal-stretch: 1;
                    }

                    Button {
                        text: "Update & Restart";
                        enabled: !root.updating;
                        clicked => {
                            root.apply-update();
                        }
                    }
                }
            }

            // ── File list ────────────────────────────────────
            Rectangle {
                border-radius: 0px;
                background: #202225;
                border-width: 0px;
                border-color: transparent;
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 8px;
                    spacing: 4px;
                    Text {
                        text: "Files (" + root.total-files + " total, " + root.selected-count + " selected)";
                        font-weight: 600;
                        font-size: 12px;
                        color: #b9bbbe;
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        ListView {
                            for item[idx] in root.file-model: FileRow {
                                index: idx;
                                file-item: item;
                                toggled => {
                                    root.toggle-file(idx);
                                }
                            }
                        }
                    }
                }
            }

            // ── Progress bar ─────────────────────────────────
            Rectangle {
                height: 4px;
                border-radius: 2px;
                background: #40444b;
                visible: root.processing || root.processed-count > 0;
                Rectangle {
                    height: 100%;
                    border-radius: 2px;
                    background: #425744;
                    width: parent.width * min(1.0, root.pct / 100.0);
                }
            }

            // ── Status bar ───────────────────────────────────
            Rectangle {
                border-radius: 6px;
                background: root.processing ? #425744 : #18191c;
                height: 30px;
                HorizontalLayout {
                    padding-left: 10px;
                    height: 30px;
                    alignment: center;
                    padding-right: 10px;
                    spacing: 8px;

                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: root.processing ? #2196f3 : root.scanning ? #ff9800 : root.error-count > 0 ? #f44336 : root.processed-count > 0 ? #425744 : #8e9297;
                        }
                    }

                    Text {
                        text: root.status-text;
                        color: #dcddde;
                        font-size: 12px;
                        horizontal-stretch: 1;
                        overflow: elide;
                        vertical-alignment: center;
                    }

                    Text {
                        text: root.processed-count + "/" + root.total-files;
                        color: #dcddde;
                        font-size: 12px;
                        vertical-alignment: center;
                        visible: root.processing || root.processed-count > 0;
                    }

                    Text {
                        text: "✓ " + root.processed-count;
                        color: #66bb6a;
                        font-size: 12px;
                        vertical-alignment: center;
                        visible: root.processed-count > 0;
                    }

                    Text {
                        text: "✗ " + root.error-count;
                        color: #ef5350;
                        font-size: 12px;
                        vertical-alignment: center;
                        visible: root.error-count > 0;
                    }

                    Text {
                        text: "⏭ " + root.skipped-count;
                        color: #ffa726;
                        font-size: 12px;
                        vertical-alignment: center;
                        visible: root.skipped-count > 0;
                    }

                    Text {
                        text: root.pct + "%";
                        color: #8e9297;
                        font-size: 12px;
                        vertical-alignment: center;
                        min-width: 32px;
                        horizontal-alignment: right;
                        visible: root.processing || root.processed-count > 0;
                    }
                }
            }
        }
    }

    // ═══ DIALOG OVERLAY — sibling of HorizontalLayout ═══════
    CompletionDialog {
        show: root.show-dialog;
        n-total: root.total-files;
        n-ok: root.processed-count;
        n-err: root.error-count;
        n-skip: root.skipped-count;
        win-width: root.width;
        win-height: root.height;
        dismiss => {
            root.show-dialog = false;
        }
    }
}
